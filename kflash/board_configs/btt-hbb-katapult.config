# BTT HBB / HBB Fe V1.0 (RP2040) -- Katapult USB (community/DIY, not BTT-documented)
# source (board identity: rp2040, USB): https://github.com/bigtreetech/HBB/blob/master/sample-bigtreetech-hbb.cfg
# source (Katapult RP2040 over USB, flashed via the BOOT button): https://github.com/Arksine/katapult/blob/master/README.md
# note: 16KiB app offset (FLASH_START_4000) is the RP2040-Katapult convention, same
# as the docs-verified in-repo ldo-nitehawk-36 (RP2040, Katapult USB) fragment.
# checked: kalico v2026.07, 2026-07-19
CONFIG_MACH_RPXXXX=y
CONFIG_MACH_RP2040=y
CONFIG_RPXXXX_FLASH_START_4000=y
CONFIG_RPXXXX_USB=y
