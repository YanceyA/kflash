# BTT HBB / HBB Fe V1.0 (RP2040) -- make flash (BOOT button / DFU)
# source (menuconfig: RP2040, No bootloader, W25Q080, USB): https://github.com/bigtreetech/HBB (User Manual V1.0 sec 4.1 "Compiling the Firmware")
# source (USB serial identity rp2040_hbb): https://github.com/bigtreetech/HBB/blob/master/sample-bigtreetech-hbb.cfg
# checked: kalico v2026.07, 2026-07-19
CONFIG_MACH_RPXXXX=y
CONFIG_MACH_RP2040=y
CONFIG_RPXXXX_FLASH_START_0100=y
CONFIG_RPXXXX_USB=y
